# ==============================================================
#   lab_llm  ·  environment configuration
# --------------------------------------------------------------
#   Copy this file to ".env" and fill in your values.
#   ".env" is gitignored. The file stays local; the key is sent
#   to your API provider for authentication.
#
#       cp .env.example .env        # macOS / Linux
#       copy .env.example .env      # Windows
#
#   Lines starting with "#" are comments and are ignored.
# ==============================================================


# --------------------------------------------------------------
#   REQUIRED  ·  your OpenAI API key
# --------------------------------------------------------------
#   Create one at:  https://platform.openai.com/api-keys
#   It starts with "sk-".  Keep it secret and never commit it.
OPENAI_API_KEY=sk-...


# --------------------------------------------------------------
#   OPTIONAL  ·  default model
# --------------------------------------------------------------
#   The model used when a call doesn't name one.
#   Change it to trade off capability, speed, and cost.
#   Browse models:  https://platform.openai.com/docs/models
DEFAULT_MODEL=gpt-5.4-mini


# --------------------------------------------------------------
#   OPTIONAL  ·  API endpoint (base URL)
# --------------------------------------------------------------
#   Where requests are sent.  Leave this commented out to use
#   OpenAI directly.  Uncomment and change it to point at a
#   compatible endpoint, such as Azure OpenAI, a local server,
#   or a proxy.  Compatibility varies by endpoint.
#   Default:  https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1


# --------------------------------------------------------------
#   OPTIONAL  ·  timeout and automatic retries
# --------------------------------------------------------------
#   lab_llm passes these settings to the OpenAI Python client.
#   Timeout is measured in seconds.  Leave them commented out to
#   use the SDK defaults.  Set retries to 0 to disable them.
# OPENAI_TIMEOUT=60
# OPENAI_MAX_RETRIES=2
